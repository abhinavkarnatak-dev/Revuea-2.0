# ── Database ────────────────────────────────────────────────
# Postgres connection string (Neon, Supabase, Railway, local…)
DATABASE_URL="postgresql://user:password@localhost:5432/revuea?schema=public"

# ── App ─────────────────────────────────────────────────────
# Public origin of the app — used for share links & OAuth callbacks
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret used to sign session cookies. Generate with:
#   openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"

# ── Google OAuth (optional — leave blank to disable the button) ──
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email (OTP delivery) ────────────────────────────────────
# Any SMTP provider works (Resend SMTP, Gmail app password, Mailgun…)
# If SMTP is not configured, OTP codes are printed to the server console
# (dev mode only — never in production).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Revuea <no-reply@revuea.app>"

# ── Gemini (AI feedback summaries) ──────────────────────────
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash-lite"
